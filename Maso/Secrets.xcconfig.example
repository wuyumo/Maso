// Secrets template — 复制成 Maso/Secrets.xcconfig 再填值.
//
// 使用步骤:
//   1. cp Maso/Secrets.xcconfig.example Maso/Secrets.xcconfig
//   2. 部署 Cloudflare Worker (见 backend/cloudflare-worker/README.md), 拿:
//      - Worker URL (https://maso-ai.<你的用户名>.workers.dev)
//      - 你设置的 MASO_CLIENT_TOKEN (任意 32+ 字符随机串)
//   3. 把下面两行替换成实际值
//   4. cd /Users/yumowu/Projects/Maso-iOS && xcodegen generate
//   5. xcodebuild build (Info.plist 自动注入 → AIWorkoutService.swift 读取)
//
// Maso/Secrets.xcconfig 已加进 .gitignore, 不会被 commit.
//
// ✅ 安全: 真正的 DeepSeek API key 不再嵌入 iOS binary —— 它在 Cloudflare Worker server-side.
//    Worker 接受请求 → 加 DeepSeek key → 转发. iOS 只持有轻量 client token (防滥用, 不是 auth).

MASO_AI_PROXY_URL = https://maso-ai.YOUR_USERNAME.workers.dev
MASO_CLIENT_TOKEN = REPLACE_WITH_RANDOM_32_CHAR_TOKEN
